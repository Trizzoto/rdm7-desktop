{
  "_comment": "Single-widget extract from widgets.schema.json — handy when reviewing diffs or onboarding contributors. Not used at build time.",
  "name": "panel",
  "display_name": "Panel",
  "singleton": false,
  "default_size": { "w": 155, "h": 92 },
  "default_position": null,
  "constraints": { "min_w": 80, "min_h": 40, "max_w": 250, "max_h": 130 },
  "fields": [
    { "name": "label",                       "label": "Header Label",     "type": "text",     "default": "",  "category": "data" },
    { "name": "custom_text",                 "label": "Unit Text",        "type": "text",     "default": "",  "category": "data" },
    { "name": "decimals",                    "label": "Decimals",         "type": "number",   "default": 0,   "category": "data" },
    { "name": "show_peak",                   "label": "Peak Hold",        "type": "select",   "default": 0,   "category": "data",
      "options": [
        { "value": 0, "label": "Off" },
        { "value": 1, "label": "Max" },
        { "value": 2, "label": "Min" },
        { "value": 3, "label": "Min/Max" }
      ] },
    { "name": "warning_high_enabled",        "label": "High Alert",       "type": "checkbox", "default": false, "category": "alerts", "group": "high" },
    { "name": "warning_high_threshold",      "label": "Threshold",        "type": "stepper",  "default": 0,    "category": "alerts", "group": "high", "min": -99999, "max": 99999, "enabled_by": "warning_high_enabled" },
    { "name": "warning_high_color",          "label": "Color",            "type": "color",    "default": "#FF0000", "category": "alerts", "group": "high", "enabled_by": "warning_high_enabled" },
    { "name": "warning_high_apply_label",    "label": "Label",            "type": "checkbox", "default": true,  "category": "alerts", "group": "high", "enabled_by": "warning_high_enabled", "inline": "warning_high_apply" },
    { "name": "warning_high_apply_value",    "label": "Value",            "type": "checkbox", "default": true,  "category": "alerts", "group": "high", "enabled_by": "warning_high_enabled", "inline": "warning_high_apply" },
    { "name": "warning_high_apply_panel",    "label": "Panel",            "type": "checkbox", "default": false, "category": "alerts", "group": "high", "enabled_by": "warning_high_enabled", "inline": "warning_high_apply" },
    { "name": "warning_low_enabled",         "label": "Low Alert",        "type": "checkbox", "default": false, "category": "alerts", "group": "low" },
    { "name": "warning_low_threshold",       "label": "Threshold",        "type": "stepper",  "default": 0,    "category": "alerts", "group": "low", "min": -99999, "max": 99999, "enabled_by": "warning_low_enabled" },
    { "name": "warning_low_color",           "label": "Color",            "type": "color",    "default": "#0000FF", "category": "alerts", "group": "low", "enabled_by": "warning_low_enabled" },
    { "name": "warning_low_apply_label",     "label": "Label",            "type": "checkbox", "default": true,  "category": "alerts", "group": "low", "enabled_by": "warning_low_enabled", "inline": "warning_low_apply" },
    { "name": "warning_low_apply_value",     "label": "Value",            "type": "checkbox", "default": true,  "category": "alerts", "group": "low", "enabled_by": "warning_low_enabled", "inline": "warning_low_apply" },
    { "name": "warning_low_apply_panel",     "label": "Panel",            "type": "checkbox", "default": false, "category": "alerts", "group": "low", "enabled_by": "warning_low_enabled", "inline": "warning_low_apply" },
    { "name": "label_font",                  "label": "Label Font",       "type": "font",     "default": "",   "category": "appearance" },
    { "name": "value_font",                  "label": "Value Font",       "type": "font",     "default": "",   "category": "appearance" },
    { "name": "border_radius",               "label": "Border Radius",    "type": "stepper",  "default": 7,    "category": "appearance", "min": 0, "max": 100 },
    { "name": "border_width",                "label": "Border Width",     "type": "stepper",  "default": 3,    "category": "appearance", "min": 0, "max": 20 },
    { "name": "border_color",                "label": "Border Color",     "type": "color",    "default": "#2E2F2E", "category": "appearance", "night_overridable": true },
    { "name": "bg_color",                    "label": "Background",       "type": "color",    "default": "#000000", "category": "appearance", "night_overridable": true },
    { "name": "bg_opa",                      "label": "BG Opacity",       "type": "stepper",  "default": 255,  "category": "appearance", "min": 0, "max": 255 },
    { "name": "label_color",                 "label": "Label Color",      "type": "color",    "default": "#FFFFFF", "category": "appearance", "night_overridable": true },
    { "name": "value_color",                 "label": "Value Color",      "type": "color",    "default": "#FFFFFF", "category": "appearance", "night_overridable": true },
    { "name": "label_y_offset",              "label": "Label Y Offset",   "type": "stepper",  "default": -28,  "category": "appearance", "min": -100, "max": 100 },
    { "name": "value_y_offset",              "label": "Value Y Offset",   "type": "stepper",  "default": 9,    "category": "appearance", "min": -100, "max": 100 },
    { "name": "custom_text_x_offset",        "label": "Unit Text X",      "type": "stepper",  "default": 41,   "category": "appearance", "min": -100, "max": 100 },
    { "name": "custom_text_y_offset",        "label": "Unit Text Y",      "type": "stepper",  "default": 32,   "category": "appearance", "min": -100, "max": 100 }
  ]
}
