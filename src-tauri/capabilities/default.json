{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-schema/main/capability.json",
  "identifier": "default",
  "description": "Default capabilities for the RDM-7 designer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten"
  ]
}
