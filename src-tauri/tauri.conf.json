{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-schema/main/tauri.conf.json",
  "productName": "RDM Studio",
  "version": "0.2.5",
  "identifier": "com.rdm7.designer",
  "build": {
    "beforeDevCommand": "python tools/merge_overlay.py",
    "beforeBuildCommand": "python tools/merge_overlay.py",
    "frontendDist": "../src/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RDM Studio",
        "width": 1400,
        "height": 900,
        "maximized": true,
        "resizable": true,
        "minWidth": 1024,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' data: blob: http://* https://*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' http://* https://* ws://* wss://*; img-src 'self' data: blob: http://* https://*",
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "rdm"
        ],
        "name": "RDM-7 Layout",
        "description": "RDM Studio layout bundle",
        "role": "Editor",
        "mimeType": "application/x-rdm"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDQjZBNDMyQzgwNjcwODEKUldTQmNBYklNcVMyL0JwbkNJYjVjOUtkdnlPWUluNzdxTEQrQWZGQlI4OTBqWUhGSHhYQ3M3elkK",
      "endpoints": [
        "https://github.com/Trizzoto/rdm7-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
